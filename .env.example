# Set these in Railway's environment variables dashboard
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_ENCRYPTION_KEY=your-random-encryption-key
WEBHOOK_URL=https://your-railway-app.up.railway.app/
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=your-railway-postgres-host
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=your-db-password
GOOGLE_APPLICATION_CREDENTIALS=/home/node/google-credentials.json
